<!DOCTYPE html>
<html>

<head>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:sans-serif;
background:#f5f5f5;
padding:10px;
}

h1{
text-align:center;
margin-bottom:15px;
}

.toolbar,
.formBox{
background:white;
padding:15px;
border-radius:12px;
margin-bottom:15px;
box-shadow:0 2px 8px rgba(0,0,0,.1);
}

input,
textarea,
button{
width:100%;
padding:10px;
margin-top:8px;
border:1px solid #ccc;
border-radius:8px;
font-size:16px;
}

textarea{
min-height:100px;
resize:vertical;
}

button{
background:#1976d2;
color:white;
border:none;
cursor:pointer;
}

button:hover{
opacity:.9;
}

.year-title{
background:#222;
color:white;
padding:10px;
border-radius:8px;
margin-top:15px;
font-size:20px;
font-weight:bold;
}

.event{
background:white;
margin-top:10px;
padding:12px;
border-radius:10px;
box-shadow:0 1px 5px rgba(0,0,0,.1);
transition:.2s;
}

.event:hover{
transform:translateY(-2px);
}

.event-title{
font-size:18px;
font-weight:bold;
}

.date{
color:#666;
font-size:13px;
}

.detail{
display:none;
margin-top:10px;
}

.detail img{
width:100%;
max-width:500px;
border-radius:10px;
margin-bottom:10px;
}

.country-tag{
display:inline-block;
padding:4px 8px;
border-radius:999px;
font-size:12px;
font-weight:bold;
background:#eee;
margin-bottom:6px;
}

.comment-box{
background:#f7f7f7;
padding:8px;
margin:5px 0;
border-radius:8px;
}

.comment-actions{
display:flex;
gap:8px;
margin-top:8px;
}

.comment-actions button{
width:auto;
padding:6px 10px;
}

#notificationArea{
background:white;
padding:10px;
border-radius:12px;
margin-bottom:15px;
box-shadow:0 2px 8px rgba(0,0,0,.1);
}

#notifications{
max-height:250px;
overflow-y:auto;
}

@media(max-width:768px){

body{
padding:8px;
}

h1{
font-size:28px;
}

.toolbar,
.formBox{
padding:12px;
}

.event-title{
font-size:16px;
}

.year-title{
font-size:18px;
}

input,
textarea,
button{
font-size:16px;
}

}
</style>

</head>

<body>

<h1>歴史年表</h1>

<div
id="notificationArea"
style="
background:white;
padding:10px;
border-radius:10px;
margin-bottom:15px;
">

<h3 id="noticeTitle">
🔔 お知らせ
</h3>

<div id="notifications">
通知はありません
</div>

</div>

<a href="https://phototourl.com/jp" target="_blank">
画像URL化サイト
</a>

<div class="toolbar">

<input
type="text"
id="searchBox"
placeholder="出来事検索"
oninput="render()">

<br><br>

<input
type="text"
id="countryFilter"
placeholder="国で検索"
oninput="render()">

<br><br>

<label>
開始年
<span id="startYearText">0</span>
</label>

<input
type="range"
id="startYear"
min="0"
max="2100"
value="0"
oninput="updateSlider()">

<label>
終了年
<span id="endYearText">2100</span>
</label>

<input
type="range"
id="endYear"
min="0"
max="2100"
value="2100"
oninput="updateSlider()">

<br><br>

<button onclick="toggleForm()">
出来事を追加
</button>

</div>

<div
id="formBox"
class="formBox"
style="display:none;">

<input
type="date"
id="eventDate">

<input
type="text"
id="eventCountry"
placeholder="国名（例：日本）">

<input
type="text"
id="eventTitle"
placeholder="出来事名">

<textarea
id="eventDescription"
placeholder="概要">
</textarea>

<input
type="text"
id="eventImage"
placeholder="画像URL">

<button onclick="saveEvent()">
保存
</button>

</div>

<div id="timeline"></div>

<script type="module">

<script type="module">

import { initializeApp }
from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";

import {
getDatabase,
ref,
push,
set,
onValue,
remove,
update
}
from "https://www.gstatic.com/firebasejs/12.15.0/firebase-database.js";

const firebaseConfig = {

/* ここを自分のFirebase設定に置き換える */

apiKey:"YOUR_API_KEY",
authDomain:"YOUR_AUTH_DOMAIN",
databaseURL:"YOUR_DATABASE_URL",
projectId:"YOUR_PROJECT_ID",
storageBucket:"YOUR_STORAGE_BUCKET",
messagingSenderId:"YOUR_SENDER_ID",
appId:"YOUR_APP_ID"

};

const app =
initializeApp(firebaseConfig);

const db =
getDatabase(app);

let events = [];
let editingId = null;

function getCountryColor(country){

let hash = 0;

for(let i=0;i<country.length;i++){

hash =
country.charCodeAt(i)
+
((hash<<5)-hash);

}

return "#" +
(
hash &
0x00FFFFFF
)
.toString(16)
.padStart(6,"0");

}

window.toggleForm = function(){

const form =
document.getElementById(
"formBox"
);

form.style.display =
form.style.display ===
"none"
?
"block"
:
"none";

}

window.updateSlider =
function(){

document.getElementById(
"startYearText"
).textContent =
document.getElementById(
"startYear"
).value;

document.getElementById(
"endYearText"
).textContent =
document.getElementById(
"endYear"
).value;

render();

}

window.saveEvent =
async function(){

const date =
eventDate.value;

const country =
eventCountry.value.trim();

const title =
eventTitle.value;

const description =
eventDescription.value;

const image =
eventImage.value;

if(!date || !title){

alert(
"日付とタイトルを入力してください"
);

return;

}

const data = {
date,
country,
title,
description,
image
};

if(editingId){

await update(
ref(
db,
"events/" + editingId
),
data
);

editingId = null;

}else{

const newRef =
push(
ref(
db,
"events"
)
);

await set(
newRef,
data
);

}

eventDate.value="";
eventCountry.value="";
eventTitle.value="";
eventDescription.value="";
eventImage.value="";

}

window.editEvent =
function(id){

const event =
events.find(
e=>e.id===id
);

editingId = id;

eventDate.value =
event.date;

eventCountry.value =
event.country || "";

eventTitle.value =
event.title;

eventDescription.value =
event.description;

eventImage.value =
event.image || "";

document.getElementById(
"formBox"
).style.display =
"block";

}

window.addComment =
async function(eventId){

const nickname =
document.getElementById(
`nickname-${eventId}`
).value.trim();

const text =
document.getElementById(
`comment-${eventId}`
).value.trim();

if(!nickname || !text){

alert(
"ニックネームとコメントを入力してください"
);

return;

}

const commentRef =
push(
ref(
db,
`events/${eventId}/comments`
)
);

await set(
commentRef,
{
nickname,
text,
time:Date.now(),
likes:0
}
);

const noticeRef =
push(
ref(db,"notifications")
);

await set(
noticeRef,
{
message:
`${nickname} さんがコメントしました`,
time:Date.now()
}
);

document.getElementById(
`comment-${eventId}`
).value="";

}

window.likeComment =
async function(
eventId,
commentId
){

const target =
events.find(
e=>e.id===eventId
);

if(
!target ||
!target.comments ||
!target.comments[commentId]
){
return;
}

const current =
target.comments[commentId]
.likes || 0;

await update(
ref(
db,
`events/${eventId}/comments/${commentId}`
),
{
likes:
current + 1
}
);

const noticeRef =
push(
ref(db,"notifications")
);

await set(
noticeRef,
{
message:
"誰かがコメントに👍しました",
time:Date.now()
}
);

}

window.deleteComment =
async function(
eventId,
commentId
){

if(
!confirm(
"コメントを削除しますか？"
)
){
return;
}

await remove(
ref(
db,
`events/${eventId}/comments/${commentId}`
)
);

}

window.deleteEvent =
function(id){

const firstConfirm =
confirm(
"本当に削除しますか？"
);

if(!firstConfirm){
return;
}

const secondConfirm =
confirm(
"この操作は元に戻せません。"
);

if(!secondConfirm){
return;
}

const answer =
prompt(
"削除するには YES と入力してください"
);

if(answer !== "YES"){

alert(
"入力が違うため削除を中止しました"
);

return;

}

remove(
ref(
db,
"events/" + id
)
);

}

window.toggleDetail =
function(id){

const detail =
document.getElementById(
"detail-" + id
);

detail.style.display =
detail.style.display ===
"block"
?
"none"
:
"block";

}

window.render =
function(){

/* この後に render本体（年表描画処理）を入れる */

}

onValue(
ref(db,"events"),
snapshot=>{

events=[];

snapshot.forEach(
child=>{

events.push({

id:child.key,

...child.val()

});

});

render();

}
);

onValue(
ref(db,"notifications"),
(snapshot)=>{

let html="";

const notices=[];

snapshot.forEach(child=>{

notices.push(
child.val()
);

});

notices.sort(
(a,b)=>b.time-a.time
);

notices.slice(0,20)
.forEach(notice=>{

html += `
<div
style="
padding:8px;
border-bottom:1px solid #ddd;
">
${notice.message}
</div>
`;

});

if(html===""){
html="通知はありません";
}

document.getElementById(
"notifications"
).innerHTML = html;

document.getElementById(
"noticeTitle"
).innerHTML =
`🔔 お知らせ (${notices.length})`;

}
);

updateSlider();

</script>

window.render =
function(){

const timeline =
document.getElementById(
"timeline"
);

timeline.innerHTML = "";

const search =
document
.getElementById(
"searchBox"
)
.value
.toLowerCase();

const countryFilter =
document
.getElementById(
"countryFilter"
)
.value
.toLowerCase();

const startYear =
parseInt(
document
.getElementById(
"startYear"
)
.value
);

const endYear =
parseInt(
document
.getElementById(
"endYear"
)
.value
);

const filtered =
events.filter(event=>{

const year =
parseInt(
event.date
.substring(0,4)
);

const matchesSearch =

(event.title || "")
.toLowerCase()
.includes(search)

||

(event.description || "")
.toLowerCase()
.includes(search);

const matchesCountry =

countryFilter === ""

||

(event.country || "")
.toLowerCase()
.includes(countryFilter);

return (
matchesSearch
&&
matchesCountry
&&
year >= startYear
&&
year <= endYear
);

});

filtered.sort(
(a,b)=>
new Date(a.date)
-
new Date(b.date)
);

const years = {};

filtered.forEach(event=>{

const year =
event.date
.substring(0,4);

if(!years[year]){

years[year]=[];

}

years[year]
.push(event);

});

Object.keys(years)
.forEach(year=>{

const yearTitle =
document.createElement(
"div"
);

yearTitle.className =
"year-title";

yearTitle.textContent =
year + "年";

timeline.appendChild(
yearTitle
);

years[year]
.forEach(event=>{

let commentsHtml="";

if(event.comments){

Object.entries(
event.comments
)

.sort(
(a,b)=>
b[1].time
-
a[1].time
)

.forEach(
([commentId,comment])=>{

commentsHtml +=
`

<div
class="comment-box">

<b>
${comment.nickname}
</b>

<br>

${comment.text}

<br><br>

<button
onclick="
likeComment(
'${event.id}',
'${commentId}'
)
">

👍
${comment.likes || 0}

</button>

<button
onclick="
deleteComment(
'${event.id}',
'${commentId}'
)
">

🗑️

</button>

</div>

`;

});

}

const color =
getCountryColor(
event.country ||
"未分類"
);

const eventDiv =
document.createElement(
"div"
);

eventDiv.className =
"event";

eventDiv.innerHTML =
`

<div
class="country-tag"
style="
background:${color};
color:white;
">

${event.country || "未分類"}

</div>

<div
class="event-title">

${event.title}

</div>

<div
class="date">

${event.date}

</div>

<button
onclick="
toggleDetail(
'${event.id}'
)
">

概要を表示

</button>

<div
id="detail-${event.id}"
class="detail">

${
event.image
?
`<img src="${event.image}">`
:
""
}

<p>

${event.description || ""}

</p>

<hr>

<button
onclick="
toggleComments(
'${event.id}'
)
">

コメントを表示

</button>

<div
id="comments-${event.id}"
style="
display:none;
">

${commentsHtml}

<input
type="text"
id="nickname-${event.id}"
placeholder="ニックネーム">

<textarea
id="comment-${event.id}"
placeholder="コメントを書く">
</textarea>

<button
onclick="
addComment(
'${event.id}'
)
">

コメント投稿

</button>

</div>

<br>

<button
onclick="
editEvent(
'${event.id}'
)
">

編集

</button>

<button
onclick="
deleteEvent(
'${event.id}'
)
">

削除

</button>

</div>

`;

timeline.appendChild(
eventDiv
);

});

});

}

</script>

</body>
</html>
